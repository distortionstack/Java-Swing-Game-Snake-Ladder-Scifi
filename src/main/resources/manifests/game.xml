<?xml version="1.0" encoding="UTF-8"?>
<assets namespace="game">

        <image key="background" file="newmap.png"/>

        <scaled key="home_button" file="but_home.png" width="84" height="87"/>

        <group key="player">
            <image key="blue"   file="player_blue.png"/>
            <image key="yellow" file="player_yellow.png"/>
            <image key="red"    file="player_red.png"/>
            <image key="white"  file="player_white.png"/>
            <image key="green"  file="player_green.png"/>
            <image key="purple" file="player_purple.png"/>
        </group>

        <group key="ufo">
            <image key="up"   file="ufo_up.gif"/>
            <image key="down" file="ufo_down.gif"/>
            <sound key="warp" file="up_down_ufo.wav"/>
        </group>

        <group key="arrow">
            <image key="up"   file="up_resize.gif"/>
            <image key="down" file="down_resize.gif"/>
        </group>

        <group key="dice_button">
            <crop key="normal"   file="but_dice.png" x="0"  y="0"  width="84" height="87"/>
            <crop key="disabled" file="but_dice.png" x="84"  y="0" width="84" height="87"/>
        </group>

        <group key="status">
            <sound key="finish" file="game_finished.wav"/>
        </group>

        <group key="dice">
            <image key="1" file="dice/1.png"/>
            <image key="2" file="dice/2.png"/>
            <image key="3" file="dice/3.png"/>
            <image key="4" file="dice/4.png"/>
            <image key="5" file="dice/5.png"/>
            <image key="6" file="dice/6.png"/>
            <sound key="roll" file="dice_roll.wav"/>
            <sound key="rolling" file="dice_rolling.wav"/>
        </group>    

    <group key="player_move">
        <sound key="move1" file="move1.wav"/>
        <sound key="move2" file="move2.wav"/>
        <sound key="move3" file="move3.wav"/>
        <sound key="move4" file="move4.wav"/>
        <sound key="move5" file="move5.wav"/>
        <sound key="move6" file="move6.wav"/>
    </group>

</assets>